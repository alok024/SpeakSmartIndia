# ─── Backend ───────────────────────────────────────────────────
# Used by next.config.ts to proxy /api/* to the Express backend.
NEXT_PUBLIC_BACKEND_URL=https://vachix-production.up.railway.app

# ─── Auth (middleware.ts) ──────────────────────────────────────
# Must be the SAME value as the backend's JWT_SECRET — middleware.ts
# verifies the ss_at cookie's signature at the edge, before any page
# renders. Server-side only; never expose with a NEXT_PUBLIC_ prefix.
JWT_SECRET=change-me-to-a-long-random-secret      # min 32 chars

# ─── Feature flags (frontend) ─────────────────────────────────
# Speech Trends card on dashboard (P5). Set to 'true' to show the card
# once a user has 3+ sessions with speech metrics. Default when absent: false
# (card hidden). Enable in production once speech metrics are collecting.
NEXT_PUBLIC_FF_SPEECH_ANALYTICS_CARD=true

# Humanised Coach badge / copy in the UI (Bug #3 fix).
# This is UI-display-only. The actual backend behaviour is controlled by
# HUMANIZE_COACH in backend/.env — not by this NEXT_PUBLIC_ variable.
NEXT_PUBLIC_FF_HUMANIZED_COACH_PROMPT=true
