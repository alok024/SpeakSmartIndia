{
  "compilerOptions": {
    "target":                 "ES2020",
    "module":                 "commonjs",
    "lib":                    ["ES2020"],
    "outDir":                 "./dist",
    "rootDir":                "./",
    "declaration":            true,
    "declarationMap":         true,
    "strict":                 true,
    "esModuleInterop":        true,
    "skipLibCheck":           true,
    "resolveJsonModule":      true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
