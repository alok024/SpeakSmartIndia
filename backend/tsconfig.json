{
  "compilerOptions": {
    "target":                          "ES2020",
    "module":                          "commonjs",
    "lib":                             ["ES2020"],
    "outDir":                          "./dist",
    "rootDir":                         "./src",
    "strict":                          false,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "resolveJsonModule":               true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError":                   false,
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
