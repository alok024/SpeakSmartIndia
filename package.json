{
  "name": "speaksmart-api",
  "version": "5.0.0",
  "main": "dist/app.js",
  "scripts": {
    "build":  "tsc",
    "start":  "node dist/app.js",
    "worker": "node dist/worker.js",
    "dev":    "ts-node-dev --respawn --transpile-only src/app.ts"
  },
  "dependencies": {
    "bcryptjs":            "^2.4.3",
    "bullmq":              "^5.4.2",
    "cors":                "^2.8.5",
    "express":             "^4.18.2",
    "express-rate-limit":  "^7.1.5",
    "helmet":              "^7.1.0",
    "ioredis":             "^5.3.2",
    "jsonwebtoken":        "^9.0.2",
    "razorpay":            "^2.9.2",
    "winston":             "^3.11.0",
    "zod":                 "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node":         "^20.11.5",
    "typescript":          "^5.3.3"
  },
  "optionalDependencies": {
    "@sentry/node": "^7.99.0"
