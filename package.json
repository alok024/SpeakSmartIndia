{
  "name": "vachix-monorepo",
  "private": true,
  "workspaces": [
    "shared",
    "frontend",
    "backend"
  ],
  "scripts": {
    "postinstall": "patch-package --patch-dir frontend/patches",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend",
    "start": "node backend/dist/app.js"
  },
  "overrides": {
    "ws": "^8.18.1",
    "undici": "^7.10.0",
    "cookie": "^0.7.2",
    "tar": "^7.4.3",
    "path-to-regexp": "0.1.12",
    "ajv": "^8.17.1",
    "eslint": "^8.57.0",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@ioredis/commands": "^1.10.0",
    "jest": "^29.7.0"
  }
}